    {
      "preset_id": "long",
      "preset_name": "长计时器",
      "duration": 300.0,
      "description": "适用于长时间倒计时，如活动倒计时"
    },
    {
      "preset_id": "gcd",
      "preset_name": "公共冷却",
      "duration": 1.0,
      "description": "GCD默认时长"
    }
  ],
  "manager_settings": {
    "max_active_timers": 100,
    "enable_debug_log": false,
    "description": "计时器管理器配置"
